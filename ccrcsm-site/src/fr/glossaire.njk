<p>Entrées ordonnées alphabétiquement. Pour les libellés arabes correspondants, voir la <a href="/ar/glossaire/">version arabe</a>.</p>

<dl class="glossary">
  {% for entry in glossaire %}
  <div id="{{ entry.id }}" class="glossary__item">
    <dt class="glossary__term">
      <strong lang="fr">{{ entry.fr.term }}</strong>
      <span class="glossary__ar" lang="ar" dir="rtl">({{ entry.ar.term }})</span>
    </dt>
    <dd class="glossary__def">{{ entry.fr.definition }}</dd>
  </div>
  {% endfor %}
</dl>
