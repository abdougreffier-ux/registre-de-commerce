---
permalink: /ar/feeds/actualites.xml
eleventyExcludeFromCollections: true
searchable: false
layout: null
---
<?xml version="1.0" encoding="utf-8"?>
<feed xmlns="http://www.w3.org/2005/Atom" xml:lang="ar">
  <title>{{ site.shortName.ar }} — الأخبار</title>
  <subtitle>{{ site.name.ar }}</subtitle>
  <link href="{{ "/ar/feeds/actualites.xml" | absoluteUrl(site.url) }}" rel="self" />
  <link href="{{ "/ar/publications/actualites/" | absoluteUrl(site.url) }}" />
  <id>{{ "/ar/publications/actualites/" | absoluteUrl(site.url) }}</id>
  {%- set latest = collections.actualites_ar | sortByDateDesc -%}
  {%- if latest and latest.length -%}
  <updated>{{ latest[0].data.date | dateISO }}T00:00:00Z</updated>
  {%- else -%}
  <updated>2026-01-01T00:00:00Z</updated>
  {%- endif %}
  {% for item in latest %}
  <entry>
    <title>{{ item.data.title }}</title>
    <link href="{{ item.url | absoluteUrl(site.url) }}" />
    <id>{{ item.url | absoluteUrl(site.url) }}</id>
    <updated>{{ item.data.date | dateISO }}T00:00:00Z</updated>
    <summary>{{ item.data.description }}</summary>
  </entry>
  {% endfor %}
</feed>
