      <td>{{ t.data.description }}</td>
      <td><time datetime="{{ t.data.date | dateISO }}">{{ t.data.date | dateAR }}</time></td>
      <td>{{ t.data.authoritativeLanguage or "FR / AR" }}</td>
    </tr>
    {% endfor %}
  </tbody>
</table>

