# ─────────────────────────────────────────────────────────────────────────────
# Fichier de configuration Django — RCCM Mauritanie
# Copier vers .env et adapter les valeurs.
# NE JAMAIS committer le fichier .env dans le dépôt git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Django core ──────────────────────────────────────────────────────────────
# SECRET_KEY : clé cryptographique JWT et sessions. Générer avec :
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=votre_cle_secrete_django_tres_longue_ici

# DEBUG : toujours False en production/test cloud
DEBUG=False

# ALLOWED_HOSTS : domaine(s) du serveur cloud séparés par virgule
# Exemple : rccm-test.mondomaine.mr,192.168.1.100
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Base de données PostgreSQL ────────────────────────────────────────────────
DB_NAME=registre_rc
DB_USER=registre_user
DB_PASSWORD=MotDePasseForte2024!
DB_HOST=localhost
DB_PORT=5432

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME_HOURS=8
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ── CORS ──────────────────────────────────────────────────────────────────────
# Origines autorisées à appeler l'API (frontend). Séparées par virgule.
# En test cloud : http://IP-DU-SERVEUR ou https://rccm-test.mondomaine.mr
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:80

# ── CSRF ──────────────────────────────────────────────────────────────────────
# Doit correspondre au(x) domaine(s) depuis lequel(s) des formulaires POST sont soumis.
CSRF_TRUSTED_ORIGINS=http://localhost,http://localhost:80

# ── Fichiers uploadés ─────────────────────────────────────────────────────────
MEDIA_ROOT=./media
MAX_UPLOAD_SIZE_MB=10

# ── Vérification publique des documents (QR codes) ───────────────────────────
# URL de base accessible depuis internet pour valider les QR codes des certificats.
# En test cloud : http://IP-DU-SERVEUR  ou  https://rccm-test.mondomaine.mr
# NE PAS laisser à localhost — les QR codes seraient inutilisables hors serveur.
RCCM_VERIFICATION_BASE_URL=http://localhost:8000

# ── Sécurité HTTPS (laisser False en HTTP, activer si TLS configuré) ─────────
SESSION_COOKIE_SECURE=False

# ── Email (optionnel — non utilisé actuellement) ──────────────────────────────
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=noreply@registrecommerce.mr
EMAIL_HOST_PASSWORD=email_password
DEFAULT_FROM_EMAIL=noreply@registrecommerce.mr
