# ─────────────────────────────────────────────────────────────────────────────
# Variables d'environnement — docker-compose RCCM Mauritanie
# Copier vers .env (au même niveau que docker-compose.yml) et adapter.
# NE JAMAIS committer le fichier .env dans le dépôt git.
# ─────────────────────────────────────────────────────────────────────────────
#
# DÉMARRAGE :
#   cp .env.example .env
#   # Éditer .env avec les vraies valeurs
#   docker-compose up --build -d
#
# ─────────────────────────────────────────────────────────────────────────────

# ── Django ────────────────────────────────────────────────────────────────────
# Générer une clé forte :
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=REMPLACER_PAR_UNE_CLE_FORTE_50_CARACTERES_MINIMUM

DEBUG=False

# Domaine(s) du serveur cloud — exemples :
#   ALLOWED_HOSTS=rccm-test.mondomaine.mr,192.168.1.100
ALLOWED_HOSTS=localhost,127.0.0.1,backend

# ── Base de données ───────────────────────────────────────────────────────────
DB_NAME=registre_rc
DB_USER=registre_user
DB_PASSWORD=REMPLACER_PAR_MOT_DE_PASSE_FORT

# DB_HOST est toujours "db" en Docker (nom du service compose) — ne pas modifier
# DB_HOST=db  <- gere automatiquement par docker-compose

# ── CORS / CSRF ───────────────────────────────────────────────────────────────
# Remplacer par l'URL publique du serveur cloud (avec le bon protocole).
# Exemples :
#   http://192.168.1.100          (IP directe, HTTP)
#   https://rccm-test.domaine.mr  (domaine avec TLS)
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:80
CSRF_TRUSTED_ORIGINS=http://localhost,http://localhost:80

# ── QR codes des documents officiels ─────────────────────────────────────────
# URL de base encodee dans les QR codes des certificats, extraits RC, attestations.
# DOIT etre accessible depuis internet (navigateur de l'utilisateur final).
# En test cloud : mettre l'URL publique du serveur (ex: http://192.168.1.100)
RCCM_VERIFICATION_BASE_URL=http://localhost

# ── Frontend React ────────────────────────────────────────────────────────────
# Laisser VIDE pour que le frontend utilise des URLs relatives (/api/...)
# proxiees par nginx vers le backend — comportement correct en Docker.
# Ne remplir QUE si le frontend est heberge sur un domaine different du backend.
REACT_APP_API_URL=

# ── pgAdmin (optionnel — demarrer avec : docker-compose --profile tools up) ──
PGADMIN_EMAIL=admin@registre.mr
PGADMIN_PASSWORD=REMPLACER_PAR_MOT_DE_PASSE_FORT
