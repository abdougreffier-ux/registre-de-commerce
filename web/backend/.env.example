# Serveur
NODE_ENV=development
PORT=5000

# Base de données PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=registre_commerce
DB_USER=rc_user
DB_PASSWORD=rc_password_secret

# JWT
JWT_SECRET=votre_jwt_secret_tres_long_et_complexe_ici
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=votre_refresh_secret_tres_long_et_complexe
JWT_REFRESH_EXPIRES_IN=7d

# Upload fichiers
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10
ALLOWED_EXTENSIONS=pdf,jpg,jpeg,png,tiff

# Logs
LOG_LEVEL=info
LOG_DIR=./logs

# Email (optionnel)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@registrecommerce.mr
SMTP_PASSWORD=email_password
EMAIL_FROM=noreply@registrecommerce.mr

# URL Frontend
FRONTEND_URL=http://localhost:3000
