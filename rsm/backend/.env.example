# RSM — variables d'environnement (exemple — ne pas commiter le .env réel)
# Les valeurs définitives seront fixées par l'exploitant après arbitrages
# d'architecture (infrastructure, source de temps, PKI, HSM).

DJANGO_SECRET_KEY=change-me-avant-mise-en-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Base de données PostgreSQL
DB_NAME=rsm
DB_USER=rsm
DB_PASSWORD=rsm
DB_HOST=localhost
DB_PORT=5432

# Langues — FR et AR sont obligatoires et ne doivent jamais être désactivées
DEFAULT_LANGUAGE=fr
TIME_ZONE=Africa/Nouakchott

# --- ZONES GELÉES (décisions institutionnelles à venir) ---
# Horodatage opposable (art. 78) — source de temps
RSM_TIMESOURCE_MODE=local_stub            # valeurs cibles: ntp_stratum_X | ptp | hsm_trusted_clock
# Scellement cryptographique (art. 78, 87, 90, 97)
RSM_SEAL_MODE=disabled                    # valeurs cibles: hmac | asymmetric_signature | chained_log
# Signature électronique (art. 88)
RSM_ESIGN_MODE=disabled                   # valeurs cibles: PKI_nationale | certificat_qualifie | autre (MO)
# Authentification forte (§ 5.1)
RSM_MFA_MODE=disabled                     # valeurs cibles: totp | x509_card | id_numerique_nationale
